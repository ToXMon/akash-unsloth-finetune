# Akash Unsloth Fine-tune Configuration
# Copy to .env and fill in values before deploying

# === Required Secrets ===
HF_TOKEN=your_huggingface_token_here
HF_REPO_ID=username/your-finetuned-model

# === Model Configuration ===
BASE_MODEL=unsloth/qwen3.5-4b-instruct-bnb-4bit
MAX_SEQ_LENGTH=2048

# === Dataset Configuration ===
DATA_SOURCE=lmms-lab/OlympiadBench
DATASET_SUBSET_SIZE=5000
DATASET_DOMAIN=medical_qa

# === LoRA Configuration ===
LORA_RANK=16
LORA_ALPHA=32
LORA_DROPOUT=0.05

# === Training Configuration ===
LEARNING_RATE=2e-4
NUM_EPOCHS=3
BATCH_SIZE=4
GRADIENT_ACCUMULATION_STEPS=4
WARMUP_STEPS=50

# === Upload Configuration ===
PUSH_MERGED=true
PUSH_ADAPTERS=true

# === Cost Control ===
HOURLY_RATE=0.75
MAX_BUDGET=3.00
